{
  // Visit https://aka.ms/tsconfig to read more about this file
  "compilerOptions": {
    // File Layout
    "rootDir": "./src",
    "outDir": "./dist",

    // Environment Settings
    // See also https://aka.ms/tsconfig/module
    "target": "es2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    
    "esModuleInterop": true,


    // Recommended Options
    "strict": true,
    "skipLibCheck": true,
  }
}
